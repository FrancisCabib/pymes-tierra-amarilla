---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import NewsCard from '@/components/NewsCard.astro'
import { getNoticias, getPymes } from '@/lib/wordpress'

export async function getStaticPaths() {
  const noticias = await getNoticias()
  return noticias.map((noticia) => ({
    params: { slug: noticia.slug },
    props: { noticia },
  }))
}

const { noticia } = Astro.props
const pymes = await getPymes()
const allNoticias = await getNoticias()
const related = allNoticias.filter((n) => n.slug !== noticia.slug).slice(0, 3)

const formattedDate = new Date(noticia.date).toLocaleDateString('es-CL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
})

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: noticia.title,
  description: noticia.excerpt,
  image: noticia.image,
  datePublished: noticia.date,
  author: {
    '@type': 'Organization',
    name: 'Pymes Tierramarilla',
  },
}
---

<BaseLayout title={noticia.title} description={noticia.excerpt} image={noticia.image} jsonLd={articleSchema}>
  <Header slot="header" />

  <article>
    <div class="relative flex min-h-[60vh] items-end overflow-hidden bg-brand-ink">
      <img
        src={noticia.image}
        alt={noticia.title}
        class="absolute inset-0 h-full w-full object-cover opacity-50"
        width="1200"
        height="630"
      />
      <div
        class="absolute inset-0"
        style="background:linear-gradient(180deg, rgba(0,26,51,0.6), rgba(0,26,51,0.95));"
        aria-hidden="true">
      </div>
      <div class="topo absolute inset-0 text-white/[0.05]" aria-hidden="true"></div>
      <div class="section-container relative pb-14 pt-32">
        <a href="/noticias" class="kicker mb-6 inline-flex items-center gap-2 text-brand-yellow hover:underline">
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Volver a noticias
        </a>
        <div class="flex flex-wrap items-center gap-2 font-mono text-xs uppercase tracking-wider text-white/70">
          {noticia.source && <span class="font-semibold text-brand-copper-light">{noticia.source}</span>}
          <span aria-hidden="true">/</span>
          <time datetime={noticia.date}>{formattedDate}</time>
        </div>
        <h1 class="display-xl mt-4 max-w-4xl text-3xl text-white sm:text-4xl lg:text-6xl">
          {noticia.title}
        </h1>
      </div>
    </div>

    <div class="bg-brand-cream py-16 lg:py-24">
      <div class="section-container">
        <div class="prose prose-lg mx-auto max-w-3xl text-text-primary" data-reveal="up">
          {noticia.content ? <div set:html={noticia.content} /> : <p>{noticia.excerpt}</p>}
        </div>

        {
          related.length > 0 && (
            <div class="mx-auto mt-20 max-w-5xl border-t border-black/10 pt-14">
              <h2 class="mb-8 font-display text-2xl font-bold text-brand-navy">Noticias relacionadas</h2>
              <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
                {related.map((item) => (
                  <NewsCard noticia={item} />
                ))}
              </div>
            </div>
          )
        }
      </div>
    </div>
  </article>

  <Footer slot="footer" pymes={pymes} />
</BaseLayout>

<style>
  .prose :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }
  .prose :global(p:first-of-type) {
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--color-text-primary);
    font-weight: 500;
  }
</style>
