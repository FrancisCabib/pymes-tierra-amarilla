---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import Hero from '@/components/Hero.astro'
import ContactForm from '@/components/ContactForm.astro'
import { getPymes } from '@/lib/wordpress'
import { siteConfig } from '@/lib/site'

const pymes = await getPymes()
---

<BaseLayout title="Contacto" description="Contáctanos a través de nuestras plataformas. Estamos para apoyar a las PYMES de Tierra Amarilla.">
  <Header slot="header" />

  <Hero compact kicker="Hablemos">
    Contáctanos
  </Hero>

  <section class="bg-brand-cream py-20 lg:py-28">
    <div class="section-container">
      <p class="mx-auto mb-14 max-w-2xl text-center text-base text-text-muted sm:text-lg" data-reveal="up">
        A través de nuestras distintas plataformas. Escríbenos y potencia tu negocio junto a la agrupación.
      </p>

      <div class="grid gap-12 lg:grid-cols-2">
        <div class="space-y-8" data-reveal="left">
          <div class="rounded-3xl border border-black/5 bg-white p-6 sm:p-8">
            <h2 class="mb-6 font-display text-xl font-bold text-brand-navy">Información de contacto</h2>
          <ul class="space-y-5">
            <li>
              <a
                href={siteConfig.whatsappLink}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 rounded-xl bg-white p-4 shadow-sm ring-1 ring-gray-100 transition-all hover:ring-brand-yellow/40"
              >
                <span class="flex h-12 w-12 items-center justify-center rounded-full bg-green-100 text-green-600">
                  <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.881 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-text-muted">WhatsApp</p>
                  <p class="font-semibold text-brand-navy">{siteConfig.whatsapp}</p>
                </div>
              </a>
            </li>
            <li>
              <a
                href={siteConfig.facebookLink}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 rounded-xl bg-white p-4 shadow-sm ring-1 ring-gray-100 transition-all hover:ring-brand-yellow/40"
              >
                <span class="flex h-12 w-12 items-center justify-center rounded-full bg-blue-100 text-blue-600">
                  <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-text-muted">Facebook</p>
                  <p class="font-semibold text-brand-navy">{siteConfig.facebook}</p>
                </div>
              </a>
            </li>
            <li>
              <a
                href={`mailto:${siteConfig.email}`}
                class="flex items-center gap-4 rounded-xl bg-white p-4 shadow-sm ring-1 ring-gray-100 transition-all hover:ring-brand-yellow/40"
              >
                <span class="flex h-12 w-12 items-center justify-center rounded-full bg-red-100 text-red-600">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-text-muted">Email</p>
                  <p class="font-semibold text-brand-navy">{siteConfig.email}</p>
                </div>
              </a>
            </li>
          </ul>
        </div>

          <div class="overflow-hidden rounded-3xl border border-black/5 shadow-lg">
            <iframe
              title="Ubicación de Tierra Amarilla, Atacama"
              src="https://www.openstreetmap.org/export/embed.html?bbox=-70.28%2C-27.52%2C-70.22%2C-27.46&layer=mapnik&marker=-27.49%2C-70.25"
              class="h-64 w-full border-0"
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <div data-reveal="right">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" pymes={pymes} />
</BaseLayout>
