---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import Hero from '@/components/Hero.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import ImageGallery from '@/components/ImageGallery.astro'
import InfoCard from '@/components/InfoCard.astro'
import PymeCard from '@/components/PymeCard.astro'
import { getPymes } from '@/lib/wordpress'
import { institucional } from '@/lib/site'

const pymes = await getPymes()
---

<BaseLayout
  title="¿Quiénes somos?"
  description="Conoce la identidad, misión y visión de la Agrupación PYMES Tierra Amarilla."
>
  <Header slot="header" />

  <Hero compact>
    ¿Quiénes Somos?
  </Hero>

  <section class="section-container py-16">
    <ImageGallery images={institucional.gallery} altPrefix="Actividades de la agrupación" />

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        institucional.blocks.map((block) => (
          <InfoCard title={block.title} content={block.content} icon={block.icon} />
        ))
      }
    </div>
  </section>

  <section class="bg-surface py-16 lg:py-24">
    <div class="section-container">
      <SectionHeading
        title="Empresas que nos acompañan"
        subtitle="Conoce a las PYMES que forman parte de nuestra agrupación."
      />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {pymes.map((pyme) => <PymeCard pyme={pyme} />)}
      </div>
    </div>
  </section>

  <Footer slot="footer" pymes={pymes} />
</BaseLayout>
