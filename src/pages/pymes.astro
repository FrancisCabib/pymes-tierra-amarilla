---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import Hero from '@/components/Hero.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import PymeGrid from '@/components/PymeGrid.astro'
import { getPymes, getPymeRubros } from '@/lib/wordpress'

const pymes = await getPymes()
const rubros = await getPymeRubros()
---

<BaseLayout
  title="Pymes y Servicios"
  description="Directorio de pequeñas y medianas empresas de Tierra Amarilla. Conoce nuestros socios y sus servicios."
>
  <Header slot="header" />

  <Hero compact>
    Conoce nuestras PYMES y Servicios
  </Hero>

  <section class="section-container py-16 lg:py-24">
    <SectionHeading
      title="Directorio de empresas"
      subtitle="Explora las PYMES que integran nuestra agrupación y descubre los servicios que ofrecen a la comunidad y la industria."
      align="left"
    />
    <PymeGrid pymes={pymes} rubros={rubros} />
  </section>

  <section class="bg-brand-navy py-12">
    <div class="section-container text-center">
      <p class="text-lg text-white/90">
        ¿Quieres trabajar con nosotros?{' '}
        <a href="/contacto" class="font-bold text-brand-yellow underline hover:no-underline">
          Contáctanos
        </a>
        , potencia tu negocio y a Tierra Amarilla.
      </p>
    </div>
  </section>

  <Footer slot="footer" pymes={pymes} />
</BaseLayout>
