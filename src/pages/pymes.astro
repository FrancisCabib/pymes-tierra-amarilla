---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import Hero from '@/components/Hero.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import PymeGrid from '@/components/PymeGrid.astro'
import { getPymes, getPymeRubros } from '@/lib/wordpress'

const pymes = await getPymes()
const rubros = await getPymeRubros()
---

<BaseLayout
  title="Pymes y Servicios"
  description="Directorio de pequeñas y medianas empresas de Tierra Amarilla. Conoce nuestros socios y sus servicios."
>
  <Header slot="header" />

  <Hero compact kicker="Directorio">
    Conoce nuestras PYMES y Servicios
  </Hero>

  <section class="bg-brand-cream py-20 lg:py-28">
    <div class="section-container">
      <SectionHeading
        kicker="Directorio de empresas"
        title="Talento que mueve el desierto"
        subtitle="Explora las PYMES que integran nuestra agrupación y descubre los servicios que ofrecen a la comunidad y la industria minera."
        align="left"
      />
      <PymeGrid pymes={pymes} rubros={rubros} />
    </div>
  </section>

  <Footer slot="footer" pymes={pymes} />
</BaseLayout>
