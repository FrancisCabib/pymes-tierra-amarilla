---
type Stat = {
  value: number
  suffix?: string
  label: string
}

const stats: Stat[] = [
  { value: 19, label: 'Microempresas asociadas' },
  { value: 12, label: 'Empresas en el directorio' },
  { value: 5, label: 'Rubros productivos' },
  { value: 100, suffix: '%', label: 'Talento de Tierra Amarilla' },
]
---

<section class="relative overflow-hidden bg-brand-navy py-16 text-white lg:py-20">
  <div class="topo absolute inset-0 text-white/[0.05]" aria-hidden="true"></div>
  <div
    class="absolute inset-0"
    style="background:radial-gradient(70% 120% at 100% 0%, rgba(224,138,79,0.3), transparent 55%);"
    aria-hidden="true"
  >
  </div>

  <div class="section-container relative">
    <dl class="grid grid-cols-2 gap-x-6 gap-y-10 lg:grid-cols-4" data-stagger>
      {
        stats.map((stat) => (
          <div class="border-l-2 border-brand-yellow/60 pl-5">
            <dt class="font-display text-5xl font-extrabold leading-none text-brand-yellow sm:text-6xl">
              <span data-count={stat.value} data-count-suffix={stat.suffix ?? ''}>
                {stat.value}
                {stat.suffix ?? ''}
              </span>
            </dt>
            <dd class="mt-3 text-sm leading-snug text-white/70">{stat.label}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
