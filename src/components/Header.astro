---
import { siteConfig } from '@/lib/site'

type NavItem = {
  label: string
  href: string
}

const navItems: NavItem[] = [
  { label: 'Inicio', href: '/' },
  { label: '¿Quiénes somos?', href: '/quienes-somos' },
  { label: 'Pymes', href: '/pymes' },
  { label: 'Noticias', href: '/noticias' },
  { label: 'Contacto', href: '/contacto' },
]

const currentPath = Astro.url.pathname

const isActive = (href: string): boolean => {
  if (href === '/') return currentPath === '/'
  return currentPath.startsWith(href)
}
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-brand-navy shadow-lg">
  <div class="section-container flex h-16 items-center justify-between gap-4 lg:h-18">
    <a
      href="/"
      class="flex shrink-0 items-center gap-2 text-white transition-opacity hover:opacity-90"
      aria-label={`${siteConfig.name} — Inicio`}
    >
      <span class="text-3xl font-extrabold text-brand-yellow" aria-hidden="true">P</span>
      <span class="hidden text-sm font-semibold tracking-tight sm:inline">ymes Tierramarilla</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Navegación principal">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-medium text-white/90 transition-colors hover:bg-white/10 hover:text-white',
              isActive(item.href) && 'border-b-2 border-brand-yellow text-white',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={siteConfig.whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full bg-brand-yellow px-3 py-2 text-xs font-semibold text-brand-navy transition-transform hover:scale-105 sm:px-4 sm:text-sm"
        aria-label="Contactar por WhatsApp"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.881 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          />
        </svg>
        <span class="hidden sm:inline">WhatsApp</span>
      </a>

      <button
        type="button"
        id="mobile-menu-btn"
        class="inline-flex items-center justify-center rounded-lg p-2 text-white hover:bg-white/10 md:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-white/10 bg-brand-navy md:hidden"
    aria-label="Navegación móvil"
  >
    <div class="section-container flex flex-col gap-1 py-3">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-lg px-3 py-3 text-sm font-medium text-white/90 hover:bg-white/10',
              isActive(item.href) && 'bg-white/10 text-brand-yellow',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false
    btn.setAttribute('aria-expanded', String(isOpen))
    btn.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú')
  })
</script>
