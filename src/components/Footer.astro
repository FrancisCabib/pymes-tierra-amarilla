---
import { siteConfig } from '@/lib/site'
import type { Pyme } from '@/lib/types'

type Props = {
  pymes?: Pyme[]
  showCta?: boolean
}

const { showCta = true } = Astro.props

const currentYear = new Date().getFullYear()
---

<footer class="relative overflow-hidden bg-brand-ink text-white">
  <div class="topo absolute inset-0 text-white/[0.04]" aria-hidden="true"></div>

  {
    showCta && (
      <div class="relative border-b border-white/10">
        <div
          class="absolute inset-0"
          style="background:radial-gradient(60% 120% at 80% 0%, rgba(224,138,79,0.35), transparent 55%);"
          aria-hidden="true"
        />
        <div class="section-container relative py-20 text-center lg:py-28" data-reveal="up">
          <p class="kicker mb-5 text-brand-yellow">¿Tienes una PYME en Tierra Amarilla?</p>
          <h2 class="display-xl mx-auto max-w-3xl text-4xl text-white sm:text-5xl lg:text-6xl">
            Hagamos crecer el desierto, juntos.
          </h2>
          <a href="/contacto" class="btn-primary mt-10" data-magnetic="0.35">
            Únete a la agrupación
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    )
  }

  <div class="section-container relative py-16">
    <div class="grid gap-12 md:grid-cols-3">
      <div>
        <div class="mb-4 flex items-center gap-2">
          <span class="font-display text-3xl font-extrabold text-brand-yellow">P</span>
          <span class="font-display font-bold">ymes Tierramarilla</span>
        </div>
        <p class="max-w-xs text-sm leading-relaxed text-white/65">{siteConfig.description}</p>
      </div>

      <div>
        <h2 class="kicker mb-5 text-brand-copper-light">Navegación</h2>
        <ul class="space-y-3 text-sm text-white/80">
          <li><a href="/" class="transition-colors hover:text-brand-yellow">Inicio</a></li>
          <li><a href="/quienes-somos" class="transition-colors hover:text-brand-yellow">¿Quiénes somos?</a></li>
          <li><a href="/pymes" class="transition-colors hover:text-brand-yellow">Pymes</a></li>
          <li><a href="/noticias" class="transition-colors hover:text-brand-yellow">Noticias</a></li>
          <li><a href="/contacto" class="transition-colors hover:text-brand-yellow">Contacto</a></li>
        </ul>
      </div>

      <div>
        <h2 class="kicker mb-5 text-brand-copper-light">Contacto</h2>
        <ul class="space-y-3 text-sm text-white/80">
          <li>
            <a href={siteConfig.whatsappLink} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-brand-yellow">
              {siteConfig.whatsapp}
            </a>
          </li>
          <li>
            <a href={siteConfig.facebookLink} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-brand-yellow">
              {siteConfig.facebook}
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.email}`} class="transition-colors hover:text-brand-yellow">
              {siteConfig.email}
            </a>
          </li>
          <li class="text-white/55">{siteConfig.address}</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-3 border-t border-white/10 pt-6 text-center font-mono text-xs text-white/45 sm:flex-row sm:text-left">
      <p>© {currentYear} {siteConfig.name}</p>
      <p>
        Desarrollado por{' '}
        <a href={siteConfig.developer.url} class="text-brand-yellow hover:underline">
          {siteConfig.developer.name}
        </a>
      </p>
    </div>
  </div>
</footer>
