---
type Props = {
  title: string
  subtitle?: string
  align?: 'left' | 'center'
}

const { title, subtitle, align = 'center' } = Astro.props
---

<div
  class:list={[
    'mb-10',
    align === 'center' ? 'text-center' : 'text-left',
  ]}
>
  <h2 class="text-2xl font-bold tracking-tight text-brand-navy sm:text-3xl lg:text-4xl">{title}</h2>
  {
    subtitle && (
      <p
        class:list={[
          'mt-3 max-w-2xl text-base leading-relaxed text-text-muted sm:text-lg',
          align === 'center' && 'mx-auto',
        ]}
      >
        {subtitle}
      </p>
    )
  }
  <div
    class:list={[
      'mt-4 h-1 w-16 rounded-full bg-brand-yellow',
      align === 'center' && 'mx-auto',
    ]}
    aria-hidden="true"
  />
</div>
