---
type Props = {
  title: string
  subtitle?: string
  kicker?: string
  align?: 'left' | 'center'
  tone?: 'dark' | 'light'
}

const { title, subtitle, kicker, align = 'center', tone = 'dark' } = Astro.props

const titleColor = tone === 'light' ? 'text-white' : 'text-brand-navy'
const subColor = tone === 'light' ? 'text-white/70' : 'text-text-muted'
---

<div
  class:list={['mb-12 max-w-3xl', align === 'center' ? 'mx-auto text-center' : 'text-left']}
  data-reveal="up"
>
  {
    kicker && (
      <p
        class:list={[
          'kicker mb-4 flex items-center gap-3 text-brand-copper',
          align === 'center' && 'justify-center',
        ]}
      >
        <span class="inline-block h-px w-8 bg-brand-copper" aria-hidden="true" />
        {kicker}
      </p>
    )
  }
  <h2 class:list={['display-xl text-3xl sm:text-4xl lg:text-5xl', titleColor]}>
    {title}
  </h2>
  {
    subtitle && (
      <p
        class:list={['mt-5 text-base leading-relaxed sm:text-lg', subColor, align === 'center' && 'mx-auto']}
      >
        {subtitle}
      </p>
    )
  }
</div>
