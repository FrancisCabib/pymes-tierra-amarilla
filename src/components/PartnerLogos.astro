---
import type { Pyme } from '@/lib/types'

type Props = {
  pymes: Pyme[]
}

const { pymes } = Astro.props
const loop = [...pymes, ...pymes]
---

<section class="overflow-hidden border-y border-black/5 bg-brand-cream py-14" aria-label="Socios destacados">
  <div class="section-container">
    <p class="kicker mb-8 flex items-center justify-center gap-3 text-brand-copper">
      <span class="inline-block h-px w-8 bg-brand-copper" aria-hidden="true"></span>
      Empresas que nos acompañan
      <span class="inline-block h-px w-8 bg-brand-copper" aria-hidden="true"></span>
    </p>
  </div>

  <div class="mask-fade-x relative">
    <div class="marquee-track flex items-center gap-5">
      {
        loop.map((pyme) => (
          <div
            class="flex h-20 w-36 shrink-0 items-center justify-center rounded-2xl border border-black/5 bg-white p-4 shadow-sm transition-transform duration-300 hover:scale-105"
            title={pyme.name}
          >
            <img
              src={pyme.logo}
              alt={`Logo ${pyme.name}`}
              class="max-h-full max-w-full object-contain opacity-80 transition-opacity hover:opacity-100"
              loading="lazy"
              width="144"
              height="80"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
