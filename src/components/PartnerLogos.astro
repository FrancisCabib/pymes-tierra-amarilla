---
import type { Pyme } from '@/lib/types'

type Props = {
  pymes: Pyme[]
}

const { pymes } = Astro.props
---

<section class="overflow-hidden bg-surface py-12" aria-label="Socios destacados">
  <div class="section-container">
    <p class="mb-6 text-center text-sm font-semibold uppercase tracking-widest text-text-muted">
      Empresas que nos acompañan
    </p>
    <div class="relative">
      <div class="flex animate-scroll gap-8" style="width: max-content;">
        {[...pymes, ...pymes].map((pyme) => (
          <div
            class="flex h-16 w-28 shrink-0 items-center justify-center rounded-xl bg-white p-3 shadow-sm ring-1 ring-gray-100"
            title={pyme.name}
          >
            <img
              src={pyme.logo}
              alt={`Logo ${pyme.name}`}
              class="max-h-full max-w-full object-contain"
              loading="lazy"
              width="112"
              height="64"
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .animate-scroll {
    animation: scroll 30s linear infinite;
  }

  .animate-scroll:hover {
    animation-play-state: paused;
  }
</style>
