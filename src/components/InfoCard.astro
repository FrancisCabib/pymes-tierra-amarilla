---
type Props = {
  title: string
  content: string
  icon: 'identity' | 'mission' | 'vision'
  index?: number
}

const { title, content, icon, index = 0 } = Astro.props

const icons = {
  identity:
    'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z',
  mission: 'M13 10V3L4 14h7v7l9-11h-7z',
  vision:
    'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
}

const num = String(index + 1).padStart(2, '0')
---

<article
  class="group relative flex h-full flex-col overflow-hidden rounded-3xl border border-black/5 bg-white p-8 transition-all duration-500 hover:-translate-y-1.5 hover:shadow-xl"
>
  <span
    class="absolute right-6 top-6 font-display text-5xl font-extrabold text-brand-navy/5 transition-colors duration-500 group-hover:text-brand-copper/15"
    aria-hidden="true">{num}</span
  >
  <div
    class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-brand-navy text-brand-yellow transition-colors duration-500 group-hover:bg-brand-copper group-hover:text-white"
  >
    <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons[icon]}></path>
    </svg>
  </div>
  <h3 class="mb-4 font-display text-xl font-bold text-brand-navy">{title}</h3>
  <p class="flex-1 text-sm leading-relaxed text-text-muted sm:text-base">{content}</p>
</article>
