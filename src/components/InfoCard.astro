---
type Props = {
  title: string
  content: string
  icon: 'identity' | 'mission' | 'vision'
}

const { title, content, icon } = Astro.props

const icons = {
  identity: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z',
  mission: 'M13 10V3L4 14h7v7l9-11h-7z',
  vision: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
}
---

<article class="flex h-full flex-col rounded-2xl bg-white p-6 shadow-md ring-1 ring-gray-100 transition-all hover:shadow-lg hover:ring-brand-yellow/30 sm:p-8">
  <div class="mb-4 flex items-center gap-3">
    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-navy/10">
      <svg class="h-6 w-6 text-brand-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons[icon]} />
      </svg>
    </div>
    <h3 class="text-lg font-bold text-brand-navy">{title}</h3>
  </div>
  <div class="mb-4 h-1 w-12 rounded-full bg-brand-yellow" aria-hidden="true" />
  <p class="flex-1 text-sm leading-relaxed text-text-muted sm:text-base">{content}</p>
</article>
