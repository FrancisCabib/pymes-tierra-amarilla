---
type Props = {
  images: string[]
  altPrefix?: string
}

const { images, altPrefix = 'Galería' } = Astro.props
---

<div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
  {
    images.map((src, index) => (
      <div class="overflow-hidden rounded-2xl shadow-md ring-1 ring-gray-100">
        <img
          src={src}
          alt={`${altPrefix} ${index + 1}`}
          class="aspect-[4/3] w-full object-cover transition-transform duration-500 hover:scale-105"
          loading="lazy"
          width="400"
          height="300"
        />
      </div>
    ))
  }
</div>
