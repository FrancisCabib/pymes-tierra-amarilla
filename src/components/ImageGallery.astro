---
type Props = {
  images: string[]
  altPrefix?: string
}

const { images, altPrefix = 'Galería' } = Astro.props

const spans = ['lg:mt-0', 'lg:mt-10', 'lg:mt-4', 'lg:mt-14']
---

<div class="grid grid-cols-2 gap-4 lg:grid-cols-4 lg:gap-6" data-stagger>
  {
    images.map((src, index) => (
      <figure
        class:list={[
          'group relative overflow-hidden rounded-3xl border border-black/5 shadow-md',
          spans[index % spans.length],
        ]}
      >
        <img
          src={src}
          alt={`${altPrefix} ${index + 1}`}
          class="aspect-[4/5] w-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
          loading="lazy"
          width="400"
          height="500"
        />
        <span
          class="absolute inset-0 bg-gradient-to-t from-brand-ink/50 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
          aria-hidden="true"
        />
      </figure>
    ))
  }
</div>
