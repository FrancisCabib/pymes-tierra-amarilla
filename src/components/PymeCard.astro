---
import type { Pyme } from '@/lib/types'

type Props = {
  pyme: Pyme
}

const { pyme } = Astro.props
---

<article
  class="group relative flex h-full flex-col overflow-hidden rounded-3xl border border-black/5 bg-white p-6 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl"
  data-rubro={pyme.rubro}
>
  {/* copper sweep on hover */}
  <span
    class="pointer-events-none absolute -right-16 -top-16 h-32 w-32 rounded-full bg-brand-copper/0 blur-2xl transition-all duration-500 group-hover:bg-brand-copper/25"
    aria-hidden="true"></span>

  <div class="relative mb-5 flex h-24 items-center justify-center overflow-hidden rounded-2xl bg-brand-cream">
    <span class="topo absolute inset-0 text-brand-navy/[0.06]" aria-hidden="true"></span>
    <img
      src={pyme.logo}
      alt={`Logo ${pyme.name}`}
      class="relative max-h-full max-w-full object-contain transition-transform duration-500 group-hover:scale-110"
      loading="lazy"
      width="160"
      height="96"
    />
  </div>

  <span
    class="mb-3 inline-flex w-fit items-center gap-1.5 rounded-full bg-brand-navy/5 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-wider text-brand-navy"
  >
    <span class="h-1.5 w-1.5 rounded-full bg-brand-copper" aria-hidden="true"></span>
    {pyme.rubro}
  </span>

  <h3 class="mb-2 font-display text-lg font-bold text-brand-navy transition-colors group-hover:text-brand-copper">
    {pyme.name}
  </h3>
  <p class="line-clamp-4 flex-1 text-sm leading-relaxed text-text-muted">{pyme.description}</p>

  {
    (pyme.website || pyme.whatsapp) && (
      <div class="mt-5 flex gap-4 border-t border-black/5 pt-4">
        {pyme.website && (
          <a
            href={pyme.website}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs font-bold text-brand-navy hover:text-brand-copper"
          >
            Sitio web
          </a>
        )}
        {pyme.whatsapp && (
          <a
            href={`https://wa.me/${pyme.whatsapp.replace(/\D/g, '')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs font-bold text-brand-navy hover:text-brand-copper"
          >
            WhatsApp
          </a>
        )}
      </div>
    )
  }
</article>
