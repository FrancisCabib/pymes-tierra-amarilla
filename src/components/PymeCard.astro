---
import type { Pyme } from '@/lib/types'

type Props = {
  pyme: Pyme
}

const { pyme } = Astro.props
---

<article
  class="group flex h-full flex-col rounded-2xl bg-white p-6 shadow-md ring-1 ring-gray-100 transition-all hover:-translate-y-1 hover:shadow-xl hover:ring-brand-yellow/40"
  data-rubro={pyme.rubro}
>
  <div class="mb-4 flex h-24 items-center justify-center rounded-xl bg-surface p-3">
    <img
      src={pyme.logo}
      alt={`Logo ${pyme.name}`}
      class="max-h-full max-w-full object-contain transition-transform group-hover:scale-105"
      loading="lazy"
      width="160"
      height="96"
    />
  </div>
  <span class="mb-2 inline-block w-fit rounded-full bg-brand-navy/10 px-3 py-1 text-xs font-semibold text-brand-navy">
    {pyme.rubro}
  </span>
  <h3 class="mb-2 text-lg font-bold text-text-primary">{pyme.name}</h3>
  <p class="line-clamp-4 flex-1 text-sm leading-relaxed text-text-muted">{pyme.description}</p>
  {
    (pyme.website || pyme.whatsapp) && (
      <div class="mt-4 flex gap-3 border-t border-gray-100 pt-4">
        {pyme.website && (
          <a
            href={pyme.website}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs font-semibold text-brand-navy-light hover:text-brand-yellow"
          >
            Sitio web
          </a>
        )}
        {pyme.whatsapp && (
          <a
            href={`https://wa.me/${pyme.whatsapp.replace(/\D/g, '')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs font-semibold text-brand-navy-light hover:text-brand-yellow"
          >
            WhatsApp
          </a>
        )}
      </div>
    )
  }
</article>
