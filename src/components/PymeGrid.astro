---
import type { Pyme } from '@/lib/types'
import PymeCard from './PymeCard.astro'

type Props = {
  pymes: Pyme[]
  rubros: string[]
  showFilter?: boolean
}

const { pymes, rubros, showFilter = true } = Astro.props
---

{
  showFilter && rubros.length > 0 && (
    <div
      class="mb-12 flex flex-wrap items-center justify-center gap-2"
      id="pyme-filters"
      role="group"
      aria-label="Filtrar por rubro"
      data-reveal="up"
    >
      <button
        type="button"
        data-rubro="todos"
        class="pyme-filter-btn is-on rounded-full border border-brand-navy bg-brand-navy px-5 py-2 font-mono text-xs uppercase tracking-wider text-white transition-all"
        aria-pressed="true"
      >
        Todos
      </button>
      {rubros.map((rubro) => (
        <button
          type="button"
          data-rubro={rubro}
          class="pyme-filter-btn rounded-full border border-black/10 bg-white px-5 py-2 font-mono text-xs uppercase tracking-wider text-brand-navy transition-all hover:border-brand-copper hover:text-brand-copper"
          aria-pressed="false"
        >
          {rubro}
        </button>
      ))}
    </div>
  )
}

<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" id="pyme-grid" data-stagger>
  {pymes.map((pyme) => <PymeCard pyme={pyme} />)}
</div>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.pyme-filter-btn')
  const cards = document.querySelectorAll<HTMLElement>('#pyme-grid article')

  const onClasses = ['is-on', 'bg-brand-navy', 'text-white', 'border-brand-navy']
  const offClasses = ['bg-white', 'text-brand-navy', 'border-black/10']

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const rubro = btn.dataset.rubro ?? 'todos'

      filterBtns.forEach((b) => {
        const isActive = b === btn
        b.setAttribute('aria-pressed', String(isActive))
        onClasses.forEach((c) => b.classList.toggle(c, isActive))
        offClasses.forEach((c) => b.classList.toggle(c, !isActive))
      })

      cards.forEach((card) => {
        const cardRubro = card.dataset.rubro
        const show = rubro === 'todos' || cardRubro === rubro
        card.style.display = show ? '' : 'none'
      })
    })
  })
</script>
