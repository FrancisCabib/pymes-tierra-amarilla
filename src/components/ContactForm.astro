---
import { siteConfig } from '@/lib/site'
---

<form
  name="contacto"
  method="POST"
  action="https://formspree.io/f/xpwzgkqr"
  class="space-y-5 rounded-2xl bg-white p-6 shadow-lg ring-1 ring-gray-100 sm:p-8"
  aria-label="Formulario de contacto"
>
  <input type="hidden" name="_subject" value="Nuevo mensaje — Pymes Tierramarilla" />
  <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="nombre" class="mb-1.5 block text-sm font-semibold text-text-primary">
        Nombre <span class="text-brand-yellow" aria-hidden="true">*</span>
      </label>
      <input
        type="text"
        id="nombre"
        name="nombre"
        required
        autocomplete="given-name"
        class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm transition-colors focus:border-brand-navy focus:outline-none focus:ring-2 focus:ring-brand-navy/20"
        placeholder="Tu nombre"
      />
    </div>
    <div>
      <label for="apellido" class="mb-1.5 block text-sm font-semibold text-text-primary">
        Apellido <span class="text-brand-yellow" aria-hidden="true">*</span>
      </label>
      <input
        type="text"
        id="apellido"
        name="apellido"
        required
        autocomplete="family-name"
        class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm transition-colors focus:border-brand-navy focus:outline-none focus:ring-2 focus:ring-brand-navy/20"
        placeholder="Tu apellido"
      />
    </div>
  </div>

  <div>
    <label for="email" class="mb-1.5 block text-sm font-semibold text-text-primary">
      Correo electrónico <span class="text-brand-yellow" aria-hidden="true">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      autocomplete="email"
      class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm transition-colors focus:border-brand-navy focus:outline-none focus:ring-2 focus:ring-brand-navy/20"
      placeholder={siteConfig.email}
    />
  </div>

  <div>
    <label for="mensaje" class="mb-1.5 block text-sm font-semibold text-text-primary">
      Mensaje <span class="text-brand-yellow" aria-hidden="true">*</span>
    </label>
    <textarea
      id="mensaje"
      name="mensaje"
      required
      rows="5"
      class="w-full resize-y rounded-xl border border-gray-200 px-4 py-3 text-sm transition-colors focus:border-brand-navy focus:outline-none focus:ring-2 focus:ring-brand-navy/20"
      placeholder="Cuéntanos cómo podemos ayudarte..."
    />
  </div>

  <button
    type="submit"
    class="w-full rounded-full bg-brand-yellow px-8 py-3.5 text-sm font-bold text-brand-navy transition-transform hover:scale-[1.02] focus:outline-none focus:ring-2 focus:ring-brand-yellow focus:ring-offset-2 sm:w-auto"
  >
    Enviar mensaje
  </button>
</form>
