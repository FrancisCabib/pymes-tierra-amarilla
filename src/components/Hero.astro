---
import { siteConfig } from '@/lib/site'

type Props = {
  compact?: boolean
  kicker?: string
}

const { compact = false, kicker } = Astro.props
---

{
  compact ? (
    <section
      class="relative flex min-h-[46vh] items-end overflow-hidden bg-brand-ink text-white"
      aria-label="Encabezado"
    >
      <div class="topo absolute inset-0 text-brand-copper/20" aria-hidden="true" />
      <div
        class="absolute inset-0"
        style="background:radial-gradient(120% 90% at 80% 0%, rgba(194,112,61,0.35), transparent 60%), radial-gradient(100% 80% at 0% 100%, rgba(0,45,86,0.9), transparent 70%);"
        aria-hidden="true"
      />
      <div class="section-container relative z-10 pb-12 pt-28">
        {kicker && (
          <p class="kicker mb-4 text-brand-yellow" data-reveal="up">
            {kicker}
          </p>
        )}
        <h1 class="display-xl text-4xl text-white sm:text-6xl lg:text-7xl" data-reveal="up">
          <slot />
        </h1>
      </div>
    </section>
  ) : (
    <section
      class="relative flex min-h-screen items-center overflow-hidden bg-brand-ink text-white"
      aria-label="Presentación principal"
    >
      {/* Layered atmosphere */}
      <div class="absolute inset-0" data-parallax="0.25" aria-hidden="true">
        <img
          src="/images/hero-bg.svg"
          alt=""
          class="h-[120%] w-full object-cover opacity-70"
          loading="eager"
          fetchpriority="high"
          width="1920"
          height="1080"
        />
      </div>
      <div
        class="absolute inset-0"
        style="background:linear-gradient(180deg, rgba(0,26,51,0.85) 0%, rgba(0,26,51,0.55) 45%, rgba(0,26,51,0.95) 100%);"
        aria-hidden="true"
      />
      <div
        class="absolute inset-0"
        style="background:radial-gradient(80% 60% at 78% 22%, rgba(224,138,79,0.45), transparent 60%);"
        aria-hidden="true"
      />
      <div class="topo absolute inset-0 text-white/[0.06]" aria-hidden="true" />

      <div class="section-container relative z-10 grid gap-12 py-32 lg:grid-cols-12 lg:items-center">
        {/* Editorial headline */}
        <div class="lg:col-span-7">
          <p class="kicker mb-6 flex items-center gap-3 text-brand-yellow" data-hero-kicker>
            <span class="inline-block h-px w-10 bg-brand-yellow" aria-hidden="true" />
            Atacama · Chile · Tierra Amarilla
          </p>

          <h1 class="display-xl text-[clamp(2.75rem,9vw,7rem)] text-white">
            <span class="block overflow-hidden">
              <span class="hero-line block">El corazón</span>
            </span>
            <span class="block overflow-hidden">
              <span class="hero-line block text-brand-yellow">emprendedor</span>
            </span>
            <span class="block overflow-hidden">
              <span class="hero-line text-outline block text-white/90">del desierto</span>
            </span>
          </h1>

          <p class="mt-8 max-w-xl text-base leading-relaxed text-white/80 sm:text-lg" data-hero-copy>
            Somos la agrupación que reúne a las PYMES de Tierra Amarilla. Conectamos a
            nuestros emprendedores con la gran minería y nuevas oportunidades de crecimiento.
          </p>

          <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center" data-hero-cta>
            <a href="/pymes" class="btn-primary" data-magnetic="0.35">
              Conoce nuestras PYMES
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
            <a href="/contacto" class="btn-ghost text-white hover:border-brand-yellow hover:text-brand-yellow">
              Quiero unirme
            </a>
          </div>

          {/* Inline stat chips */}
          <dl class="mt-14 grid max-w-lg grid-cols-3 gap-6 border-t border-white/15 pt-8">
            <div data-hero-stat>
              <dt class="font-display text-3xl font-extrabold text-brand-yellow sm:text-4xl">
                <span data-count="19">19</span>
              </dt>
              <dd class="mt-1 text-xs text-white/60">Microempresas asociadas</dd>
            </div>
            <div data-hero-stat>
              <dt class="font-display text-3xl font-extrabold text-brand-yellow sm:text-4xl">
                <span data-count="12">12</span>
              </dt>
              <dd class="mt-1 text-xs text-white/60">Empresas en el directorio</dd>
            </div>
            <div data-hero-stat>
              <dt class="font-display text-3xl font-extrabold text-brand-yellow sm:text-4xl">
                <span data-count="100" data-count-suffix="%">100%</span>
              </dt>
              <dd class="mt-1 text-xs text-white/60">Talento local</dd>
            </div>
          </dl>
        </div>

        {/* Floating brand card */}
        <div class="lg:col-span-5" data-hero-card>
          <div class="relative mx-auto max-w-sm">
            <div
              class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-brand-copper/40 to-brand-yellow/20 blur-2xl"
              aria-hidden="true"
            />
            <div class="relative overflow-hidden rounded-[2rem] border border-white/15 bg-white/10 p-8 backdrop-blur-md">
              <div class="topo absolute inset-0 text-white/[0.07]" aria-hidden="true" />
              <div class="relative flex flex-col items-center text-center">
                <span class="display-xl text-8xl text-brand-yellow drop-shadow-2xl" aria-hidden="true">
                  P
                </span>
                <p class="kicker mt-4 text-brand-yellow">Agrupación PYMES</p>
                <p class="font-display text-2xl font-extrabold tracking-tight text-white">
                  Tierra Amarilla
                </p>
                <div class="mt-6 h-px w-full bg-white/15" aria-hidden="true" />
                <p class="mt-6 text-sm text-white/70">
                  Unidos por el desarrollo económico y social de nuestra comuna.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Scroll cue */}
      <a
        href="#contenido"
        class="absolute bottom-8 left-1/2 z-10 hidden -translate-x-1/2 flex-col items-center gap-2 text-white/60 transition-colors hover:text-brand-yellow lg:flex"
        aria-label="Desplazarse hacia abajo"
      >
        <span class="kicker text-[0.6rem]">Scroll</span>
        <span class="flex h-10 w-6 justify-center rounded-full border border-current pt-2">
          <span class="h-2 w-1 animate-bounce rounded-full bg-current" aria-hidden="true" />
        </span>
      </a>
    </section>
  )
}
